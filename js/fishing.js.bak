const JUNK_TABLE = [
  { id: 'old_boot',    name: 'Old Boot',     icon: '👢', flavour: 'Waterlogged and falling apart. Not yours, hopefully.' },
  { id: 'tin_can',     name: 'Tin Can',      icon: '🥫', flavour: 'Rusted through. Something once lived inside it.' },
  { id: 'soggy_hat',   name: 'Soggy Hat',    icon: '🎩', flavour: 'A fine hat, once. The river has had its way with it.' },
  { id: 'tangled_net', name: 'Tangled Net',  icon: '🕸',  flavour: 'Someone lost this long ago. Easy to see why.' },
  { id: 'river_stone', name: 'Smooth Stone', icon: '🪨', flavour: 'Perfectly round. The river shaped it over centuries.' },
  { id: 'broken_rod',  name: 'Broken Rod',   icon: '🎣', flavour: 'Another fisher\'s misfortune. Maybe it snapped on a big one.' },
  { id: 'old_coin',    name: 'Old Coin',     icon: '🪙', flavour: 'Worn smooth. The face on it is unrecognisable.' },
];
const JUNK_CHANCE = 0.07; // 7% chance any cast pulls up junk

const RARITY_COLORS = {
  common:   '#a0c880',
  uncommon: '#70b8e0',
  rare:     '#e8a020',
  legendary:'#e060f0',
  junk:     '#807060',
};

// ── Session catch log (persisted to localStorage) ──

function _loadCatchLog() {
  try { return JSON.parse(localStorage.getItem('kw_catch_log') || '[]'); }
  catch { return []; }
}
function _saveCatch(fishId) {
  const log = _loadCatchLog();
  log.push({ fishId, ts: Date.now() });
  if (log.length > 100) log.splice(0, log.length - 100);
  try { localStorage.setItem('kw_catch_log', JSON.stringify(log)); } catch {}
  _updateCatchDisplay();
}
function _getCatchCounts() {
  const log = _loadCatchLog();
  return log.reduce((acc, e) => { acc[e.fishId] = (acc[e.fishId] || 0) + 1; return acc; }, {});
}

// ── Season → fish pool ────────────────────────

function _getSeasonalPool() {
  const season = (typeof calcCurrentSeason === 'function')
    ? calcCurrentSeason().id
    : (typeof currentSeason !== 'undefined' && currentSeason?.id) || 'spring';
  return FISH_TABLE.filter(f => f.seasons.includes(season));
}

function _rollFish() {
  // Small chance of junk
  if (Math.random() < JUNK_CHANCE) {
    const junk = JUNK_TABLE[Math.floor(Math.random() * JUNK_TABLE.length)];
    return { ...junk, rarity: 'junk', difficulty: 1, value: 0, weight: 0, seasons: [] };
  }
  const pool = _getSeasonalPool();
  if (!pool.length) return FISH_TABLE[0];
  const totalWeight = pool.reduce((s, f) => s + f.weight, 0);
  let roll = Math.random() * totalWeight;
  for (const fish of pool) {
    roll -= fish.weight;
    if (roll <= 0) return fish;
  }
  return pool[pool.length - 1];
}

// ── Open / Close ──────────────────────────────

async function visitFishingPost() {
  const overlay = document.getElementById('fishing-overlay');
  if (!overlay) return;
  overlay.style.display = 'flex';
  _resetFishingState();
  // Ensure citizensData is fresh so the fisher dropdown renders correctly
  if (typeof loadCitizens === 'function') await loadCitizens();
  _renderFishingHome();
  _updateCatchDisplay();
}

function leaveFishingPost() {
  const overlay = document.getElementById('fishing-overlay');
  if (overlay) overlay.style.display = 'none';
  _reelStop();
  _stopMinigame();
}

// ── Main fishing screen ───────────────────────

function _renderFishingHome() {
  const area = document.getElementById('fishing-main-area');
  if (!area) return;
  const season = (typeof calcCurrentSeason === 'function') ? calcCurrentSeason() : { name: 'Spring', emoji: '🌸' };
  const pool = _getSeasonalPool();

  // Build fisher dropdown from citizensData
  const fishers = (typeof citizensData !== 'undefined' ? citizensData : [])
    .filter(c => c.role === 'fisher');

  const fisherDropdown = fishers.length
    ? `<div class="fp-fisher-row">
        <label class="fp-fisher-label">👤 Fishing with</label>
        <select class="fp-fisher-select" id="fp-fisher-select" onchange="_onFisherChange(this.value)">
          ${fishers.map(c => {
            const skill = c.skills?.fishing ?? 1;
            return `<option value="${c.id}" data-skill="${skill}">${c.name} (Fishing ${skill})</option>`;
          }).join('')}
        </select>
      </div>`
    : `<div class="fp-fisher-none">No citizens assigned to <em>Fisher</em> role.</div>`;

  // Set initial skill from first fisher
  if (fishers.length) {
    _selectedFisherSkill = fishers[0].skills?.fishing ?? 1;
  }

  area.innerHTML = `
    <div class="fp-intro">
      <div class="fp-flavor">The river runs quiet here. ${season.emoji} <em>${season.name}</em> brings its own catch.</div>
    </div>
    <div class="fp-available-fish">
      <div class="fp-fish-label">In Season</div>
      <div class="fp-fish-list">
        ${pool.map(f => `
          <span class="fp-fish-pill" style="color:${RARITY_COLORS[f.rarity]}">
            ${f.icon} ${f.name}
          </span>
        `).join('')}
      </div>
    </div>
    ${fisherDropdown}
    <button class="fp-cast-btn" id="fp-cast-btn" onclick="startFishing()">🎣 Cast Line</button>
    <div class="fp-result-area" id="fp-result-area"></div>
  `;
}

// ── Minigame state ────────────────────────────

let _fishState = 'idle'; // idle | waiting | active | success | fail

// ── Audio ──────────────────────────────────────
let _reelAudio = null;
let _biteAudio  = null;
let _failAudio  = null;

function _playBiteSound() {
  if (!_biteAudio) { _biteAudio = new Audio('/assets/audio/fishcatch.wav'); _biteAudio.volume = 0.7; }
  _biteAudio.currentTime = 0;
  _biteAudio.play().catch(() => {});
}
function _playFailSound() {
  if (!_failAudio) { _failAudio = new Audio('/assets/audio/fail.wav'); _failAudio.volume = 0.6; }
  _failAudio.currentTime = 0;
  _failAudio.play().catch(() => {});
}
function _playSuccessSound() {
  const a = new Audio('/assets/audio/success.mp3');
  a.volume = 0.75;
  a.play().catch(() => {});
}
function _getReelAudio() {
  if (!_reelAudio) {
    _reelAudio = new Audio('/assets/audio/reel.wav');
    _reelAudio.loop = true;
    _reelAudio.volume = 0.55;
  }
  return _reelAudio;
}
function _reelStart() {
  const a = _getReelAudio();
  if (a.paused) a.play().catch(() => {});
}
function _reelStop() {
  if (_reelAudio && !_reelAudio.paused) {
    _reelAudio.pause();
    _reelAudio.currentTime = 0;
  }
}
let _fishTarget = null;
let _minigameLoop = null;
let _biteTimeout = null;

// Minigame physics
let _catchBarY   = 50;  // 0–100, position of player bar
let _targetY     = 40;  // 0–100, position of fish target zone
let _targetVY    = 0;   // target velocity
let _progress    = 0;   // 0–100, catch progress
let _holding     = false;
let _currentFish = null;

const CATCH_BAR_HEIGHT = 17; // % of meter — reduced by ~1/3 from previous 26
const TARGET_HEIGHT    = 24;
const PROGRESS_FILL_RATE  = 0.32;  // slow — takes ~10s of solid overlap to catch
const PROGRESS_DRAIN_RATE = 0.295; // slightly more punishing — can't just idle
const BAR_RISE_SPEED  = 1.6;       // was 2.5
const BAR_FALL_SPEED  = 1.1;       // was 1.8
const TARGET_ACCEL    = 0.22;      // was 0.6 — calmer target movement
const TARGET_MAX_V    = 1.8;       // was 3.5

function _resetFishingState() {
  _fishState = 'idle';
  _fishTarget = null;
  _reelStop();
  _stopMinigame();
  _holding = false;
  _progress = 0;
  if (_biteTimeout) { clearTimeout(_biteTimeout); _biteTimeout = null; }
}

function _onFisherChange(citizenId) {
  const citizen = (typeof citizensData !== 'undefined' ? citizensData : [])
    .find(c => c.id === parseInt(citizenId));
  _selectedFisherSkill = citizen?.skills?.fishing ?? 1;
}

function startFishing() {
  if (_fishState !== 'idle') return;
  _fishState = 'waiting';

  const area = document.getElementById('fishing-main-area');
  if (!area) return;

  const castBtn = document.getElementById('fp-cast-btn');
  if (castBtn) { castBtn.disabled = true; castBtn.textContent = '🎣 Line in water…'; }

  const resultArea = document.getElementById('fp-result-area');
  if (resultArea) resultArea.innerHTML = '';

  // Animate bobber
  const bobber = document.getElementById('fp-bobber-float');
  if (bobber) bobber.classList.add('cast');

  // Random bite delay 2–5 seconds
  const biteDelay = 2000 + Math.random() * 3000;
  _biteTimeout = setTimeout(() => _fishBite(), biteDelay);
}

function _fishBite() {
  if (_fishState !== 'waiting') return;
  _fishState = 'biting';
  _currentFish = _rollFish();
  _playBiteSound();
  _renderBiteAlert();

  // 1-second window to click
  _biteTimeout = setTimeout(() => {
    if (_fishState === 'biting') {
      // Missed the window
      _fishState = 'fail';
      _playFailSound();
      _renderGotAway();
    }
  }, 1000);
}

function _renderBiteAlert() {
  const area = document.getElementById('fishing-main-area');
  if (!area) return;
  const isJunk = _currentFish.rarity === 'junk';
  area.innerHTML = `
    <div class="fp-bite-alert" id="fp-bite-alert" onclick="confirmBite()">
      <div class="fp-bite-pulse"></div>
      <div class="fp-bite-icon">${isJunk ? '❓' : '🎣'}</div>
      <div class="fp-bite-text">${isJunk ? 'Something snagged the line!' : "Something's biting!"}</div>
      <div class="fp-bite-sub">Click now!</div>
      <div class="fp-bite-timer-bar"><div class="fp-bite-timer-fill" id="fp-bite-timer-fill"></div></div>
    </div>
  `;
  // Animate the timer bar shrinking over 1s
  requestAnimationFrame(() => {
    const fill = document.getElementById('fp-bite-timer-fill');
    if (fill) {
      fill.style.transition = 'width 1s linear';
      fill.style.width = '0%';
    }
  });
}

function confirmBite() {
  if (_fishState !== 'biting') return;
  clearTimeout(_biteTimeout);
  _biteTimeout = null;

  // Junk — skip minigame, go straight to junk result
  if (_currentFish.rarity === 'junk') {
    _fishState = 'success';
    _showJunkResult();
    return;
  }

  _fishState = 'active';
  _catchBarY = 50;
  _targetY   = 30 + Math.random() * 40;
  _targetVY  = (Math.random() - 0.5) * 2;
  _progress  = 25;
  _renderMinigame();
  _startMinigameLoop();
}

function _renderGotAway() {
  const area = document.getElementById('fishing-main-area');
  if (!area) return;
  area.innerHTML = `
    <div class="fp-result fp-result-fail">
      <div class="fp-result-splash">💨 It got away!</div>
      <div class="fp-result-fish-icon" style="opacity:0.35">${_currentFish?.icon || '🐟'}</div>
      <div class="fp-result-flavour"><em>The line went slack before you could react.</em></div>
      <div class="fp-result-actions">
        <button class="fp-cast-btn" onclick="startFishingAgain()">🎣 Try Again</button>
        <button class="fp-leave-btn" onclick="leaveFishingPost()">← Leave</button>
      </div>
    </div>
  `;
}

function _showJunkResult() {
  const junk = _currentFish;
  _saveCatch(junk.id);
  const area = document.getElementById('fishing-main-area');
  if (!area) return;
  area.innerHTML = `
    <div class="fp-result fp-result-junk">
      <div class="fp-result-splash">🪣 You pulled up…</div>
      <div class="fp-result-fish-icon">${junk.icon}</div>
      <div class="fp-result-fish-name" style="color:#a09080">${junk.name}</div>
      <div class="fp-result-rarity" style="color:#807060">junk</div>
      <div class="fp-result-flavour"><em>${junk.flavour}</em></div>
      <div class="fp-result-actions">
        <button class="fp-cast-btn" onclick="startFishingAgain()">🎣 Cast Again</button>
        <button class="fp-leave-btn" onclick="leaveFishingPost()">← Leave</button>
      </div>
    </div>
  `;
}

// ── Minigame render ───────────────────────────

// Dynamic catch bar height — harder fish = smaller window, higher fisher skill = larger window
let _selectedFisherSkill = 1; // set from dropdown, default 1

function _getTargetHeight() {
  const d = _currentFish?.difficulty || 1;
  // diff 1 → 20%, diff 10 → 8% — tighter window overall
  const base = Math.round(20 - (d - 1) * 1.35);
  // Fisher skill 1–10 adds 0–8% extra
  const skillBonus = Math.round((_selectedFisherSkill - 1) * 0.9);
  return Math.min(28, Math.max(6, base + skillBonus));
}

function _renderMinigame() {
  const area = document.getElementById('fishing-main-area');
  if (!area) return;

  area.innerHTML = `
    <div class="fp-minigame">
      <div class="fp-mg-fish-hint">
        🎣 Something's on the line!
      </div>
      <div class="fp-mg-instruction">Hold <kbd>Space</kbd> or <kbd>Click</kbd> to raise — release to fall</div>
      <div class="fp-mg-arena" id="fp-mg-arena">
        <div class="fp-mg-progress-wrap">
          <div class="fp-mg-progress-fill" id="fp-mg-progress" style="height:${_progress}%"></div>
          <div class="fp-mg-progress-label" id="fp-mg-progress-label">📈</div>
        </div>
        <div class="fp-mg-meter" id="fp-mg-meter">
          <div class="fp-mg-target" id="fp-mg-target"
               style="top:${_targetY}%; height:${_getTargetHeight()}%">
            <div class="fp-mg-target-fish">${_currentFish.icon}</div>
          </div>
          <div class="fp-mg-bar" id="fp-mg-bar"
               style="top:${_catchBarY}%; height:${CATCH_BAR_HEIGHT}%">
          </div>
        </div>
      </div>
      <div class="fp-mg-hint">Keep the <span class="fp-mg-hint-green">green bar</span> on the fish!</div>
    </div>
  `;

  // Input listeners — mousedown/up on the arena, plus keyboard
  const meter = document.getElementById('fp-mg-meter');
  if (meter) {
    meter.addEventListener('mousedown', _holdStart);
    meter.addEventListener('touchstart', _holdStart, { passive: true });
  }
}

function _holdStart(e) {
  e.preventDefault?.();
  if (_fishState !== 'active') return;
  _holding = true;
  _reelStart();
}
function _holdEnd(e) {
  _holding = false;
  _reelStop();
}

// Global key + mouse listeners attached once
document.addEventListener('keydown', e => {
  if (e.code === 'Space') {
    e.preventDefault();
    if (_fishState === 'biting') {
      confirmBite();
    } else if (_fishState === 'active') {
      if (!_holding) { _holding = true; _reelStart(); }
    }
  }
});
document.addEventListener('keyup', e => {
  if (e.code === 'Space') { _holding = false; _reelStop(); }
});
document.addEventListener('mouseup', _holdEnd);
document.addEventListener('touchend', _holdEnd);

// ── Minigame loop ─────────────────────────────

function _startMinigameLoop() {
  _stopMinigame();
  let last = performance.now();

  function tick(now) {
    if (_fishState !== 'active') return;
    const dt = Math.min((now - last) / 16.67, 3); // normalised to ~60fps
    last = now;

    // Move catch bar
    if (_holding) {
      _catchBarY = Math.max(0, _catchBarY - BAR_RISE_SPEED * dt);
    } else {
      _catchBarY = Math.min(100 - CATCH_BAR_HEIGHT, _catchBarY + BAR_FALL_SPEED * dt);
    }

    // Move fish target — exponential difficulty curve: diff 1=gentle, diff 10=brutal
    const d = (_currentFish?.difficulty || 1);
    const diffScale = 0.18 + Math.pow(d / 10, 1.6) * 2.2;
    // Higher difficulty also causes sudden direction reversals
    if (d >= 7 && Math.random() < 0.008 * d * dt) _targetVY *= -1.4;
    _targetVY += (Math.random() - 0.48) * TARGET_ACCEL * diffScale * dt;
    _targetVY = Math.max(-TARGET_MAX_V * diffScale, Math.min(TARGET_MAX_V * diffScale, _targetVY));
    _targetY += _targetVY * dt;

    // Bounce off edges
    if (_targetY < 0) { _targetY = 0; _targetVY = Math.abs(_targetVY); }
    if (_targetY > 100 - _getTargetHeight()) { _targetY = 100 - _getTargetHeight(); _targetVY = -Math.abs(_targetVY); }

    // Check overlap
    const barTop    = _catchBarY;
    const barBot    = _catchBarY + CATCH_BAR_HEIGHT;
    const targTop   = _targetY;
    const targBot   = _targetY + _getTargetHeight();
    const overlaps  = barTop < targBot && barBot > targTop;

    // Progress
    if (overlaps) {
      _progress = Math.min(100, _progress + PROGRESS_FILL_RATE * dt);
    } else {
      _progress = Math.max(0, _progress - PROGRESS_DRAIN_RATE * dt);
    }

    // Update DOM
    const barEl      = document.getElementById('fp-mg-bar');
    const targetEl   = document.getElementById('fp-mg-target');
    const progEl     = document.getElementById('fp-mg-progress');
    const progLabel  = document.getElementById('fp-mg-progress-label');
    if (barEl)    barEl.style.top    = `${_catchBarY}%`;
    if (targetEl) targetEl.style.top = `${_targetY}%`;
    if (progEl) {
      progEl.style.height = `${_progress}%`;
      progEl.style.background = overlaps
        ? 'linear-gradient(180deg,#a0e060,#60b030)'
        : 'linear-gradient(180deg,#e0a040,#c06820)';
    }
    if (progLabel) progLabel.textContent = _progress > 70 ? '🎣' : _progress > 35 ? '📈' : '📉';

    // Win / lose
    if (_progress >= 100) { _catchSuccess(); return; }
    if (_progress <= 0)   { _catchFail();    return; }

    _minigameLoop = requestAnimationFrame(tick);
  }

  _minigameLoop = requestAnimationFrame(tick);
}

function _stopMinigame() {
  if (_minigameLoop) { cancelAnimationFrame(_minigameLoop); _minigameLoop = null; }
  if (_biteTimeout)  { clearTimeout(_biteTimeout); _biteTimeout = null; }
  _holding = false;
}

// ── Outcomes ──────────────────────────────────

function _catchSuccess() {
  _fishState = 'success';
  _reelStop();
  _stopMinigame();
  _playSuccessSound();
  const fish = _currentFish;
  _saveCatch(fish.id);

  const area = document.getElementById('fishing-main-area');
  if (!area) return;

  area.innerHTML = `
    <div class="fp-result fp-result-success">
      <div class="fp-result-splash">✨ Caught! ✨</div>
      <div class="fp-result-fish-icon">${fish.icon}</div>
      <div class="fp-result-fish-name" style="color:${RARITY_COLORS[fish.rarity]}">${fish.name}</div>
      <div class="fp-result-rarity">${fish.rarity}</div>
      <div class="fp-result-flavour"><em>${fish.flavour}</em></div>
      <div class="fp-result-actions">
        <button class="fp-cast-btn" onclick="startFishingAgain()">🎣 Cast Again</button>
        <button class="fp-leave-btn" onclick="leaveFishingPost()">← Leave</button>
      </div>
    </div>
  `;
}

function _catchFail() {
  _fishState = 'fail';
  _reelStop();
  _stopMinigame();
  _playFailSound();
  _renderGotAway();
}

function startFishingAgain() {
  _fishState = 'idle';
  _currentFish = null;
  _stopMinigame();
  _renderFishingHome();
}

// ── Catch log display ─────────────────────────

function _updateCatchDisplay() {
  const el = document.getElementById('fp-catch-log');
  if (!el) return;
  const counts = _getCatchCounts();
  const total = Object.values(counts).reduce((a, b) => a + b, 0);
  if (!total) {
    el.innerHTML = '<div class="fp-cl-empty">No catches yet.</div>';
    return;
  }
  el.innerHTML = FISH_TABLE
    .filter(f => counts[f.id])
    .map(f => `
      <div class="fp-cl-row">
        <span>${f.icon} ${f.name}</span>
        <span class="fp-cl-count" style="color:${RARITY_COLORS[f.rarity]}">×${counts[f.id]}</span>
      </div>
    `).join('');
}
